{
  "ConnectionStrings": {
    "AppDatabase": "Host=localhost;Port=5432;Database=langoose_app;Username=langoose;Password=langoose",
    "CorpusDatabase": "Host=localhost;Port=5432;Database=langoose_corpus;Username=langoose;Password=langoose"
  },
  "feature_management": {
    "feature_flags": [
      { "id": "EnableUserEntriesImport", "enabled": false }
    ]
  },
  "UserEntriesImport": {
    "PollIntervalSeconds": 60,
    "BatchSize": 1000,
    "MaxRetries": 3
  },
  "CorpusImport": {
    "PollIntervalSeconds": 60,
    "BatchSize": 1000,
    "Heuristic": {
      "MinLength": 2,
      "MaxLength": 300,
      "PosBlocklist": [ "name", "abbrev", "symbol", "intj" ]
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
