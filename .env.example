# Local-compose defaults. Copy to .env on first checkout
# (cp .env.example .env). The same variable NAMES are configured in
# Railway (api, worker) and Vercel (web) for staging/production —
# values there are environment-specific and managed in those dashboards.
#
# .env is gitignored so each developer can override values locally
# (e.g. POSTGRES_DATA_PATH for a specific volume mount).

# Postgres container (local only — staging/production use Neon)
POSTGRES_USER=langoose
POSTGRES_PASSWORD=langoose
POSTGRES_DB=postgres

# Connection strings (Npgsql / .NET format)
ConnectionStrings__AppDatabase=Host=postgres;Port=5432;Database=langoose_app;Username=langoose;Password=langoose
ConnectionStrings__AuthDatabase=Host=postgres;Port=5432;Database=langoose_auth;Username=langoose;Password=langoose
ConnectionStrings__CorpusDatabase=Host=postgres;Port=5432;Database=langoose_corpus;Username=langoose;Password=langoose

# API runtime
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# Worker runtime
DOTNET_ENVIRONMENT=Development

# Web (nginx -> SPA runtime config)
LANGOOSE_API_BASE_URL=/api

# Suppresses Npgsql's GSS encryption probe (libgssapi_krb5).
# Flip to "prefer" only if the database moves behind Kerberos / AD auth.
PGGSSENCMODE=disable

# Playwright (e2e)
PLAYWRIGHT_BASE_URL=http://app-web
